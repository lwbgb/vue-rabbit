{
  "$schema": "https://json.schemastore.org/prettierrc",
  "semi": true,
  "singleQuote": true,
  "printWidth": 120,
  "tabWidth": 4,
  "bracketSameLine": true,
  "singleAttributePerLine": false,
  "arrowParens": "avoid",
  "overrides": [
    {
      "files":["*.html", "*.vue", "*.jsp", "*.json", "*.scss"],
      "options": {
        "tabWidth": 2
      }
    }
  ]
}
