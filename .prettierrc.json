{
  "$schema": "https://json.schemastore.org/prettierrc",
  "semi": true,
  "singleQuote": true,
  "printWidth": 100,
  "tabWidth": 4,
  "bracketSameLine": true,
  "singleAttributePerLine": false,
  "overrides": [
    {
      "files":["*.html", "*.vue", "*.jsp", "*.json"],
      "options": {
        "tabWidth": 2
      }
    }
  ]
}
